# Shopify Storefront API
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token
SHOPIFY_API_VERSION=2025-01

# Shopify Customer Account API (Headless channel > Customer Account API)
# Public clients only need the client ID. Confidential clients also need the secret.
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=your-customer-account-client-id
# SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_SECRET=your-customer-account-client-secret

# Public site URL (used for sitemap.xml, robots.txt, and OAuth callbacks)
# NEXT_PUBLIC_SITE_URL=https://rokn-jade.vercel.app

# Optional: override the exact OAuth callback URL registered in Shopify admin
# SHOPIFY_CUSTOMER_ACCOUNT_REDIRECT_URI=https://your-subdomain.ngrok-free.app/api/customer-auth/callback
